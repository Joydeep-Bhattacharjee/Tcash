# QueueStorm Investigator — environment
# All optional. Service runs fully deterministic with zero config.

# HTTP server
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# LLM enrichment (OPTIONAL). If absent, prose uses safe deterministic templates.
# The service NEVER depends on these to answer — graceful fallback always.
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_TIMEOUT_MS=8000
